// catalog-service/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  // Recomendación: No usar output personalizado para evitar errores en Docker
  // output = "../generated/prisma" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo de Géneros
model Genero {
  id        Int        @id @default(autoincrement())
  nombre    String     @db.VarChar(50)
  
  // Relación implícita con Películas
  peliculas Pelicula[]

  @@map("generos")
}

// Modelo de Películas (Solo datos del contenido, sin usuarios ni favoritos)
model Pelicula {
  id               String   @id @default(uuid()) @db.Uuid
  titulo           String   @db.VarChar(200)
  descripcion      String   @db.Text
  fechaLanzamiento DateTime @map("fecha_lanzamiento") @db.Date
  duracion         Int
  
  // Rutas de archivos multimedia
  rutaCaratula     String   @map("ruta_caratula") @db.VarChar(500)
  rutaVideo        String   @map("ruta_video") @db.VarChar(500)
  rutaImagenFondo  String   @map("ruta_imagen_fondo") @db.VarChar(500)
  rutaTrailer      String   @map("ruta_trailer") @db.VarChar(500)

  // Relaciones
  generos          Genero[]

  @@map("peliculas")
}